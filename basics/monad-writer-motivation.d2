...@styles

direction: down

before: without Writer monad: log threaded as explicit variables {
  direction: right
  step1 -> step2 -> step3 -> result
  step1: "step1(x) → (r1, log1)"
  step2: "step2(r1, log1) → (r2, log2)"
  step3: "step3(r2, log2) → (r3, log3)"
  result: "(r3, log3)"
  step1.class: [
    function
    f
  ]
  step2.class: [
    function
    g
  ]
  step3.class: [
    function
    h
  ]
  result.class: [
    type
    b
  ]
  note: passing log1 instead of log2 silently drops entries
  note.class: [comment]
}

after: with Writer monad: log accumulation is automatic {
  direction: right
  step1 -> step2 -> step3 -> result
  step1 -> step2: ">>="
  step2 -> step3: ">>="
  step3 -> result: ">>="
  step1.class: [
    function
    f
  ]
  step2.class: [
    function
    g
  ]
  step3.class: [
    function
    h
  ]
  result.class: [
    type
    a
  ]
  result: "runWriter"
  result: {tooltip: runWriter returns the final result and the combined log in order}
}
