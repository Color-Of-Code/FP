{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "lib": ["ES2022", "DOM"],
    "types": ["node", "d3", "jsdom"]
  },
  "include": [
    "sysml/**/*.ts",
    "check-lang-order.ts",
    "vitest.config.ts"
  ]
}
