{
  "name": "fp-tools",
  "private": true,
  "type": "module",
  "description": "Dev tooling for the FP repository",
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "lint:md": "markdownlint-cli2 '../**/*.md' '!../node_modules/**' '!./node_modules/**' '!./vscode-sysml/node_modules/**' '!./vscode-sysml/dist/**'",
    "lint:langs": "node --experimental-strip-types check-lang-order.ts",
    "fmt:md": "prettier --write '../**/*.md'",
    "check:md": "prettier --check '../**/*.md'",
    "test": "vitest run",
    "test:update": "vitest run -u",
    "typecheck": "tsc --noEmit",
    "langium:gen": "langium generate"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^25.6.0",
    "langium": "^4.2.2",
    "langium-cli": "^4.2.1",
    "markdownlint-cli2": "^0.17.2",
    "prettier": "^3.5.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "elkjs": "^0.11.1",
    "jsdom": "^26.1.0",
    "xmlbuilder2": "^4.0.3"
  }
}
