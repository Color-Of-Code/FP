{
  "name": "fp-tools",
  "private": true,
  "type": "module",
  "description": "Dev tooling for the FP repository",
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "lint:md": "markdownlint-cli2 '../**/*.md' '!../node_modules/**' '!./node_modules/**' '!./vscode-sysml/node_modules/**' '!./vscode-sysml/dist/**'",
    "lint:langs": "node --experimental-strip-types check-lang-order.ts",
    "fmt:md": "prettier --write '../**/*.md'",
    "check:md": "prettier --check '../**/*.md'",
    "test": "vitest run",
    "test:update": "vitest run -u",
    "typecheck": "tsc --noEmit",
    "langium:gen": "langium generate"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/jsdom": "^28.0.1",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.6.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "eslint-plugin-functional": "^9.0.4",
    "jiti": "^2.7.0",
    "langium": "^4.2.3",
    "langium-cli": "^4.2.1",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.5.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.32.1",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "elkjs": "^0.11.1",
    "jsdom": "^29.1.1",
    "lodash-es": "^4.17.21",
    "xmlbuilder2": "^4.0.3"
  }
}
