{
  "name": "fp-tools",
  "private": true,
  "type": "module",
  "description": "Dev tooling for the FP repository",
  "scripts": {
    "lint:md": "markdownlint-cli2 '../**/*.md' '!../node_modules/**'",
    "lint:langs": "node --experimental-strip-types check-lang-order.ts",
    "fmt:md": "prettier --write '../**/*.md'",
    "check:md": "prettier --check '../**/*.md'",
    "test": "vitest run",
    "test:update": "vitest run -u",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^25.6.0",
    "markdownlint-cli2": "^0.17.2",
    "prettier": "^3.5.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "chevrotain": "^12.0.0",
    "d3": "^7.9.0",
    "elkjs": "^0.11.1",
    "jsdom": "^26.1.0"
  }
}
