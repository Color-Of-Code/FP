    "tooltips": {
      "pa": "Parser a — a function String ⟶ Maybe (a, String): consumes a prefix, returns (a, rest) or Nothing",
      "f": "(a ⟶ Parser b) — the next parser, built from the parsed value a",
      "input": "String — the full input. pa consumes a prefix; rest is passed forward (like State monad).",
      "run_pa": "Run pa(input): on success produces (a, rest); on failure produces Nothing",
      "a_val": "a — the parsed value. Passed to f to build the next parser.",
      "rest": "String — unconsumed input after pa ran. Flows to run_pb (not input). This is the State-like threading.",
      "apply_f": "Apply f(a): build Parser b from the parsed value a",
      "pb": "Parser b — the second parser",
      "run_pb": "Run pb(rest): parse b from the REMAINING input, not from the original input",
      "b": "b — the final parsed value",
      "rest2": "String — input still unconsumed after both parsers ran",
      "fail_in": "Nothing — pa failed. No (a, rest) was produced.",
      "fail_out": "Nothing — propagated unchanged. f is never called. (Same short-circuit as Maybe bind.)"
    },
    "title": "Parser bind: thread rest to f(a)  |  Nothing → Nothing  (f skipped) — also called: flatMap, Bind, >>=",
    "name": "bind"
  }
