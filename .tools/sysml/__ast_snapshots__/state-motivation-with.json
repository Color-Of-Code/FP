    "tooltips": {
      "initial": "Plain input value of type A — does not include the state.",
      "pureA": "pure : A → State s A. Returns (a, s) — leaves s untouched.",
      "bindStep1": ">>= : runs the State action, threads s' into step1, returns step1's (b, s'').",
      "bindStep2": ">>= : threads the latest state into step2 automatically. No way to supply the wrong state.",
      "bindStep3": ">>= : threads the latest state into step3 automatically.",
      "step1Fn": "step1 : A → State s B. HOF argument — its input is A, not State s A.",
      "step2Fn": "step2 : B → State s C. Same: supplied to bind as the continuation.",
      "step3Fn": "step3 : C → State s D. Same: supplied to bind as the continuation.",
      "outResult": "runState s0 supplies the initial state and returns the final value alongside the final state."
    },
    "title": "With pure + bind: state threads automatically; using a stale state is impossible",
