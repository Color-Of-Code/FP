    "tooltips": {
      "sa_val": "State s a — a computation: given state s returns (a, s')",
      "f_val": "(a ⟶ State s b) — continuation: given result a, produces a new state computation",
      "s_in": "s — current state entering bind. The value side and the state side are both threaded.",
      "bind": "bind sa f = \\\\s ->\\n  let (a, s')  = sa(s)    -- run sa: get result a and new state s'\\n      (b, s'') = f(a)(s') -- run f(a) with s': get b and final state s''\\n  in  (b, s'')",
      "sb_val": "State s b — the composed computation; when run it produces (b, s'')",
      "s_out": "s — the transformed state after both sa and f(a) have run. Different from s_in."
    },
