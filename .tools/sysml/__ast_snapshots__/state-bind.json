    "tooltips": {
      "sa": "State s a — a computation: given state s returns (a, s')",
      "f": "(a ⟶ State s b) — the continuation; given result a, builds the next state computation",
      "s0": "s — the initial state entering the bind. Flows into run_sa.",
      "run_sa": "Run sa(s0): execute the first computation. Produces BOTH result a AND new state s1.",
      "a": "a — the value result of sa(s0). Passed to f.",
      "s1": "s — the state AFTER running sa. This is s1 ≠ s0. It is s1 (not s0) that flows to run_sb. Critical difference from Reader.",
      "apply_f": "Apply f(a): build the next computation State s b from result a",
      "sb": "State s b — the second computation, not yet run",
      "run_sb": "Run f(a)(s1): execute the second computation with the UPDATED state s1. s0 is not used here.",
      "b": "b — the final value result",
      "s2": "s — the final state after both steps. s0 ≠ s1 ≠ s2 in general; each step transforms the state."
    },
    "title": "State bind: s0 → run sa → (a, s1) → run f(a)(s1) → (b, s2)",
    "name": ">>="
  }
