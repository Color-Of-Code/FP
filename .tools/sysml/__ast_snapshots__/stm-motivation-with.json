    "tooltips": {
      "readA": "readTVar accountA : STM Int — STM action. Read tracked, not committed alone.",
      "bindWriteA": ">>= : sequences writeA(-delta) and the readB step. Reads/writes accumulate in the transaction.",
      "bindWriteB": ">>= : sequences writeB(+delta). Final step before commit.",
      "writeAThenFn": "λaVal. writeTVar accountA (aVal - delta) >> readTVar accountB. HOF argument — captures aVal in scope.",
      "writeBFn": "λbVal. writeTVar accountB (bVal + delta). HOF argument — captures bVal.",
      "commit": "atomically — commits all four operations as one unit, or restarts the whole transaction on conflict. No deadlock possible."
    },
    "title": "With pure + bind: STM actions compose freely; runtime commits atomically or retries",
