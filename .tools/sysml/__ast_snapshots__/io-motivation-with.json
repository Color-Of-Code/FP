    "tooltips": {
      "path": "FilePath — plain input. Pure callers see only this in the API.",
      "purePath": "pure : FilePath → IO FilePath. Lifts the plain path so the chain can start uniformly with bind.",
      "bindRead": ">>= : sequences readFile after pure. The runtime guarantees this effect happens before the next bind.",
      "bindLogComp": ">>= : sequences the (logMessage cfg >> compute cfg) continuation. Effect order is deterministic.",
      "readFileFn": "readFile : FilePath → IO Config. HOF argument — its input is FilePath, not IO FilePath, so it cannot sit on the main flow.",
      "logCompFn": "λcfg. logMessage cfg >> compute cfg : Config → IO Int. HOF argument — runs both side-effects in order, both seeing cfg.",
      "ioResult": "IO Int — the final described program. The runtime (main) is the only thing that actually executes it."
    },
    "title": "With pure + bind: effects in the type, sequenced explicitly through bind",
    "name": "compute"
  }
