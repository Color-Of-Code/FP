    "tooltips": {
      "sa": "STM a — an atomic action that reads/writes TVars. Not yet executed.",
      "f": "(a ⟶ STM b) — given result a, builds the next atomic action",
      "run_sa": "Run sa: read/write TVars; result is tentative until atomically commits",
      "a": "a — the value produced by sa (tentative)",
      "build": "Apply f(a): build the next atomic action STM b",
      "sb": "STM b — the next atomic action",
      "run_sb": "Run f(a): read/write TVars; all writes still tentative",
      "b_raw": "b — the result value (still tentative, not yet committed)",
      "commit": "atomically: check for TVar conflicts.\\n  No conflict  → commit all writes at once; b is visible to other threads\\n  Conflict     → discard ALL tentative writes; restart the entire chain from run_sa",
      "b": "b — the committed result. All TVar writes from run_sa and run_sb are now atomically visible.",
      "retry": "Retry path — the entire transaction restarts. No partial state is visible to other threads."
    },
    "title": "STM bind: sequence two TVar actions; atomically commits or retries the whole chain — also called: >>=",
