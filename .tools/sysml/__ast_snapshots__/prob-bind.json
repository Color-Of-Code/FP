    "tooltips": {
      "dist_a": "Prob a = [(a, p)] — each (a, pa) is an outcome with probability pa. Repeats for every element (∀ a).",
      "f": "(a ⟶ Prob b) — conditional distribution: given each outcome a, returns a distribution over b",
      "a1": "Outcome a1 from Prob a",
      "pa1": "P(A = a1) — probability of outcome a1",
      "a2": "Outcome a2 from Prob a",
      "pa2": "P(A = a2) — probability of outcome a2",
      "branch1": "Apply f(a1): get the conditional distribution Prob b given A = a1",
      "branch2": "Apply f(a2): get the conditional distribution Prob b given A = a2",
      "sub1": "Prob b — conditional distribution for branch a1",
      "sub2": "Prob b — conditional distribution for branch a2",
      "weight1": "Scale: each (b, pb) in sub1 gets weight pa1 * pb — P(B=b | A=a1) * P(A=a1)",
      "weight2": "Scale: each (b, pb) in sub2 gets weight pa2 * pb — P(B=b | A=a2) * P(A=a2)",
      "w1": "[(b, pa1·pb)] — weighted outcomes for branch a1",
      "w2": "[(b, pa2·pb)] — weighted outcomes for branch a2",
      "merge": "Concatenate: w1 ++ w2 (and repeat for all other branches). Result is the marginal distribution P(B).",
      "dist_b": "Prob b — the marginal distribution: P(B=b) = Σ_a P(B=b|A=a)·P(A=a)"
    },
    "title": "Prob bind: apply f per outcome, weight by pa, merge — law of total probability — also called: flatMap, SelectMany, >>=",
