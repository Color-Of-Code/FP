    "tooltips": {
      "pa_val": "Parser a = String ⟶ Maybe (a, String) — run on input; succeeds with (a, rest) or fails with Nothing",
      "f_val": "(a ⟶ Parser b) — given parsed value a, constructs the next parser (runs on the remaining input)",
      "rest": "String — the unconsumed remainder after pa_val runs. bind threads it into f(a). Nothing short-circuits (like Maybe).",
      "bind": "bind p f = \\\\input ->\\n  case p(input) of\\n    Nothing       -> Nothing        -- propagate failure\\n    Just (a, rest) -> f a rest      -- thread rest into next parser",
      "pb_val": "Parser b — the composed parser; on success returns (b, rest2) where rest2 is what f(a) didn't consume"
    },
