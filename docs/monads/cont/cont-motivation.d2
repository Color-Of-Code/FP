...@../../styles

direction: down

before: without callCC: early exit requires a sentinel threaded back through every layer {
  direction: right
  step1 -> check1 -> step2 -> check2 -> step3 -> final
  step1: step1
  check1: "== ABORT?"
  step2: step2
  check2: "== ABORT?"
  step3: step3
  final: result
  step1.class: [
    function
    f
  ]
  check1.class: [
    function
    g
  ]
  step2.class: [
    function
    f
  ]
  check2.class: [
    function
    g
  ]
  step3.class: [
    function
    h
  ]
  final.class: [
    type
    b
  ]
  note: every caller must inspect the return value and propagate ABORT manually
  note.class: [comment]
}

after: with callCC: the escape function jumps directly to the runCont call site {
  direction: right
  callCC -> step1 -> step2 -> step3 -> runCont
  callCC -> step1: ">>="
  step1 -> step2: ">>="
  step2 -> step3: ">>="
  step3 -> runCont: ">>="
  callCC: callCC
  step1: step1
  step2: step2
  step3: step3
  runCont: runCont
  callCC.class: [
    function
    h
  ]
  step1.class: [
    function
    f
  ]
  step2.class: [
    function
    g
  ]
  step3.class: [
    function
    f
  ]
  runCont.class: [
    type
    a
  ]
  exit: "exit a"
  callCC -> runCont: exit shortcut
  exit.class: [
    value
    b
  ]
  runCont: {tooltip: exit(a) applies the captured continuation k directly; all remaining steps are skipped}
}
