direction: right

...@../../styles

callCC_def: "callCC :: ((a -> Cont r b) -> Cont r a) -> Cont r a" {
  f -> callCC
  callCC -> result
  f: "f :: (a -> Cont r b) -> Cont r a"
  result: "Cont r a"
  escape: "escape :: a -> Cont r b"
  callCC -> escape: provides
  f -> escape: receives
  f.class: [
    function
    f
  ]
  callCC.class: [
    function
    g
  ]
  result.class: [
    type
    a
  ]
  escape.class: [
    value
    b
  ]
  callCC: {tooltip: Capture the current continuation k as an escape function. Calling escape(a) jumps directly to the runCont call site with value a.}
}
