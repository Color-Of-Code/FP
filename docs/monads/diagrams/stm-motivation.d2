...@../../styles

direction: down

before: without STM: explicit locks require careful ordering to avoid deadlock {
  direction: right
  lock_a -> lock_b -> update_a -> update_b -> unlock_b -> unlock_a
  lock_a:   "lock(accountA)"
  lock_b:   "lock(accountB)"
  update_a: "accountA -= amount"
  update_b: "accountB += amount"
  unlock_b: "unlock(accountB)"
  unlock_a: "unlock(accountA)"
  lock_a.class: [
    function
    g
  ]
  lock_b.class: [
    function
    g
  ]
  update_a.class: [
    function
    f
  ]
  update_b.class: [
    function
    f
  ]
  unlock_b.class: [
    function
    g
  ]
  unlock_a.class: [
    function
    g
  ]
  deadlock: Thread 2 locks B then A — deadlock if Thread 1 holds A
  deadlock.class: [comment]
}

after: with STM: compose reads and writes freely — runtime prevents conflicts {
  direction: right
  read_a -> write_a -> read_b -> write_b -> commit
  read_a -> write_a: ">>="
  write_a -> read_b: ">>="
  read_b -> write_b: ">>="
  write_b -> commit: atomically
  read_a:  "readTVar accountA"
  write_a: "writeTVar accountA"
  read_b:  "readTVar accountB"
  write_b: "writeTVar accountB"
  commit:  "IO ()"
  read_a.class: [
    function
    f
  ]
  write_a.class: [
    function
    f
  ]
  read_b.class: [
    function
    g
  ]
  write_b.class: [
    function
    g
  ]
  commit.class: [
    type
    a
  ]
  commit: {tooltip: atomically commits all writes at once, or retries the whole transaction on conflict. No locks to order.}
}
