...@../styles

direction: down

monad_view: Monad — inject and chain {
  direction: right
  a: a {
    class: [
      value
      a
    ]
  }
  ma: "M a" {
    class: [
      type
      a
    ]
  }
  mb: "M b" {
    class: [
      type
      b
    ]
  }
  a -> ma: "pure: inject context"
  ma -> mb: "bind: use value,\nreturn new context"
}

comonad_view: Comonad — extract and broadcast {
  direction: right
  wa: "W a" {
    class: [
      type
      a
    ]
  }
  a2: a {
    class: [
      value
      a
    ]
  }
  wb: "W b" {
    class: [
      type
      b
    ]
  }
  wa -> a2: "extract: focus value"
  wa -> wb: "extend: use whole\ncontext, produce new"
}

example: Stream comonad example {
  stream: "Stream: [a₀, a₁, a₂, …]" {
    class: definition
  }
  ext: "extract = head (current focus)"
  dup: "extend f = apply f to every suffix"
  stream -> ext
  stream -> dup
}

monad_view -> comonad_view: dual {
  style.stroke-dash: 5
}
