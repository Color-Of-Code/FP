direction: right

...@../styles

def_fold: fold :: (b ⟶ a ⟶ b) ⟶ b ⟶ List<a> ⟶ b {
  f -> fold: {class: hof-conn}
  b0 -> fold
  as -> fold
  fold -> result
  f: f :: b ⟶ a ⟶ b
  b0: b (init)
  as: List<a>
  result: b (result)
  f.class: [hof]
  b0.class: [
    type
    b
  ]
  as.class: [
    type
    a
  ]
  result.class: [
    type
    b
  ]
  fold.class: [
    function
    g
  ]
  fold: {tooltip: Reduce a collection List<a> to a single value b by repeatedly applying the combining function f}
}

def_fold: {tooltip: A higher-order function that reduces a structure to a single value using a combining function and an initial accumulator}

derived: derived operations (via fold) {
  explanation: |md
    # map, filter and more are all folds

    - **sum** — f = (+),  init = 0
    - **product** — f = (×),  init = 1
    - **length** — f = (acc, _) ⟶ acc + 1,  init = 0
    - **map g** — f = (acc, x) ⟶ acc ++ [g(x)],  init = []
    - **filter p** — f = (acc, x) ⟶ if p(x) then acc ++ [x] else acc,  init = []
  |
  explanation.class: [comment]
}
