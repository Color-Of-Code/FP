...@../../styles

direction: down

before: without prism: full case expression at every call site {
  direction: right
  f1: "updateRadius shape ="
  f2: "  case shape of"
  f3: "    Circle r -> Circle (r * 2)"
  f4: "    _        -> shape"
  note: "Repeated for every function that touches Circle. Cannot compose."
  f1.class: [code]
  f2.class: [code]
  f3.class: [code]
  f4.class: [code]
  note.class: [comment]
}

after: with prism: a first-class handle to one constructor {
  direction: right
  prism_val -> ops_over
  prism_val -> ops_preview
  prism_val -> ops_review
  prism_val: "_Circle :: Prism' Shape Double"
  ops_over: "over _Circle (*2) shape"
  ops_preview: "preview _Circle shape"
  ops_review: "review  _Circle 5.0"
  prism_val.class: [definition]
  ops_over.class: [value; a]
  ops_preview.class: [value; b]
  ops_review.class: [value; a]
  prism_val: {tooltip: One value; all operations use it. Composable with Lens and Traversal.}
}
