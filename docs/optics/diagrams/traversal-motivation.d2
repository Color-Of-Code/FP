...@../../styles

direction: down

before: without traversal: ad hoc map per combination {
  direction: right
  f1: "doubled = map (map (*2)) nested"
  f2: "totalPrice = sum (map (.price) (orders cart))"
  note: "Each combination of container + field writes its own map call. No reuse."
  f1.class: [code]
  f2.class: [code]
  note.class: [comment]
}

after: with traversal: compose once; any aggregator works {
  direction: right
  path -> over_op
  path -> sum_op
  path -> list_op
  path -> all_op
  path: "traverse . traverse\norders . each . price"
  over_op: "over t (*2) nested"
  sum_op: "sumOf t cart"
  list_op: "toListOf t cart"
  all_op: "allOf t (>100) cart"
  path.class: [definition]
  over_op.class: [value; a]
  sum_op.class: [value; b]
  list_op.class: [value; b]
  all_op.class: [value; c]
}
